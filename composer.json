{
    "name": "franpass87/fp-digital-marketing-suite",
    "description": "FP Digital Marketing Suite - A comprehensive digital marketing toolkit",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Francesco Passeri",
            "email": "info@francescopasseri.com",
            "homepage": "https://francescopasseri.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "dompdf/dompdf": "^2.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^1.10",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpunit/phpunit": "^9.6"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "process-timeout": 600
    },
    "scripts": {
        "phpcs": "phpcs --standard=.phpcs.xml",
        "phpcbf": "phpcbf --standard=.phpcs.xml",
        "phpstan": "phpstan analyse --configuration=phpstan.neon --memory-limit=512M",
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text"
    }
}